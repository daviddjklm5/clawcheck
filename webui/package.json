{
  "name": "clawcheck-webui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "preinstall": "node ../automation/scripts/check_webui_supply_chain_ioc.js --webui-dir .",
    "preflight": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ..\\automation\\scripts\\preflight_webui_node.ps1",
    "security:check-supply-chain": "node ../automation/scripts/check_webui_supply_chain_ioc.js --webui-dir .",
    "dev": "vite",
    "build": "npm run preflight && npm run security:check-supply-chain && tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.3.9",
    "@mui/material": "7.3.9",
    "@mui/x-data-grid": "8.27.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-router-dom": "7.13.1"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "typescript": "5.9.3",
    "vite": "8.0.0"
  }
}
