{
  "name": "clawcheck-chat-extension",
  "displayName": "clawcheck Chat",
  "description": "Optional VS Code WebView entry for clawcheck chat workspace.",
  "version": "0.1.0",
  "publisher": "clawcheck",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:clawcheck.openChatPanel"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "clawcheck.openChatPanel",
        "title": "clawcheck: Open Chat Panel"
      }
    ],
    "configuration": {
      "title": "clawcheck Chat",
      "properties": {
        "clawcheck.chatApiBaseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8000/api",
          "description": "Base URL for clawcheck API. Must include /api suffix."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -p . -w"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.96.0",
    "typescript": "^5.8.0"
  }
}

